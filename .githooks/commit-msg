#!/bin/sh

msg_file="$1"

cleaned_message="$(sed '/^#/d' "$msg_file" | sed '/^[[:space:]]*$/d')"
subject="$(printf '%s\n' "$cleaned_message" | head -n 1)"
body="$(printf '%s\n' "$cleaned_message" | sed '1d')"

if [ -z "$subject" ]; then
  echo "커밋 메시지 제목이 비어 있습니다." >&2
  exit 1
fi

if ! printf '%s\n' "$subject" | grep -Eq '[가-힣]'; then
  echo "커밋 메시지 제목은 기본적으로 한글로 작성해야 합니다." >&2
  echo "예: 문서: Homebrew 배포 경로 정리" >&2
  exit 1
fi

subject_length=$(printf '%s' "$subject" | wc -m | tr -d ' ')
if [ "$subject_length" -gt 72 ]; then
  echo "커밋 메시지 제목은 72자 이내로 유지하세요." >&2
  exit 1
fi

body_line_count=$(printf '%s\n' "$body" | sed '/^[[:space:]]*$/d' | wc -l | tr -d ' ')
if [ "$body_line_count" -gt 3 ]; then
  echo "커밋 메시지 바디는 중요한 내용만 3줄 이내로 요약하세요." >&2
  exit 1
fi

if printf '%s\n' "$cleaned_message" | grep -Eiq \
  '(generated by|written by|authored by|created by|ai-assisted|ai generated|using ai|with ai|with claude|with codex|with cursor|with gemini|with chatgpt|co-authored-by:.*(ai|claude|codex|cursor|gemini|chatgpt)|ai로 작성|ai 사용|claude로 작성|codex로 작성|cursor로 작성|gemini로 작성|chatgpt로 작성)'; then
  echo "커밋 메시지에는 어떤 AI를 사용했는지 쓰지 마세요." >&2
  exit 1
fi

exit 0
