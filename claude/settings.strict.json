{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-files.sh",
            "_source": "ai-setting"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous-commands.sh",
            "_source": "ai-setting"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-main-branch.sh",
            "_source": "ai-setting"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-on-write.sh",
            "_source": "ai-setting"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/async-test.sh",
            "_source": "ai-setting"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v osascript >/dev/null 2>&1; then osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'; elif command -v powershell.exe >/dev/null 2>&1; then powershell.exe -Command \"[void](New-Object -ComObject Wscript.Shell).Popup('Claude Code needs your attention',1,'Claude Code',64)\" 2>/dev/null || true; elif command -v notify-send >/dev/null 2>&1; then notify-send 'Claude Code' 'Claude Code needs your attention'; fi",
            "_source": "ai-setting"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-context.sh write strict",
            "_source": "ai-setting"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/compact-backup.sh write strict",
            "_source": "ai-setting"
          },
          {
            "type": "prompt",
            "prompt": "Check if the last task involved code changes. If so, verify: 1) Were tests run or clearly explained? 2) Were docs updated if behavior changed? 3) Were any risky issues left unresolved? If verification is missing, respond with {\"ok\": false, \"reason\": \"Please run the relevant tests and update the related docs before finishing.\"}. Otherwise respond with {\"ok\": true}.",
            "_source": "ai-setting"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-context.sh read strict",
            "_source": "ai-setting"
          }
        ]
      }
    ]
  }
}
